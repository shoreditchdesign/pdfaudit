{
  "name": "hsbc-pdf-audit-tool",
  "private": true,
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "scripts": {
    "setup": "./scripts/setup.sh",
    "audit": "bash ./scripts/audit.sh",
    "dev": "concurrently -k -n backend,frontend -c red,blue \"./scripts/dev.sh\" \"npm --prefix frontend run dev\"",
    "stop": "./scripts/stop.sh",
    "dev:frontend": "npm --prefix frontend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "test:frontend": "npm --prefix frontend run test",
    "dev:backend": "./scripts/dev.sh",
    "test:backend": "./scripts/test.sh",
    "lint:frontend": "npm --prefix frontend run lint"
  }
}
